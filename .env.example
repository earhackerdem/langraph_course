OPENAI_API_KEY=
GOOGLE_API_KEY=

# LLM: use openai (default) or ollama for local models (Ollama must be running).
# Default Ollama model matches local gpt-oss:20b; override with OLLAMA_MODEL if needed.
LLM_BACKEND=openai
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini
OLLAMA_MODEL=gpt-oss:20b
# Optional: lighter model for the booking agent; defaults to OLLAMA_MODEL if unset.
# OLLAMA_MINI_MODEL=
OLLAMA_BASE_URL=http://127.0.0.1:11434

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DB_URI=